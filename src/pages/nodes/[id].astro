---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { NodeDetail } from '@/components/PageWrappers';
import { nodes } from '@/lib/data';

export function getStaticPaths() {
  return nodes.map((n) => ({
    params: { id: n.id }
  }));
}

const { id } = Astro.params;
---
<BaseLayout title="Node Details - Aether Panel">
  <NodeDetail client:only="react" id={id} />
</BaseLayout>
