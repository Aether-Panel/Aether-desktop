---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ServerDetail } from '@/components/PageWrappers';
import { servers } from '@/lib/data';

export function getStaticPaths() {
  return servers.map((server) => ({
    params: { id: server.id }
  }));
}

const { id } = Astro.params;
---
<BaseLayout title="Server Details - Aether Panel">
  <ServerDetail client:only="react" id={id} />
</BaseLayout>
